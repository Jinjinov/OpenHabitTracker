@using OpenHabitTracker.App
@using OpenHabitTracker.Data
@using OpenHabitTracker.Data.Models
@using OpenHabitTracker.Services

@inject ICalendarService CalendarService
@inject IHabitService HabitService
@inject ClientState ClientState
@inject IStringLocalizer Loc
@inject IJsInterop JsInterop

@if (Habit is null || Habit.TimesDoneByDay is null)
{
    @* <p>Failed to load. Try refreshing.</p> *@
}
else
{
    @if (DisplayMonth)
    {
        <div class="input-group mb-1">
            <button class="btn btn-outline-primary" aria-label="@Loc["Previous week"]" @onclick="_calendarParams.SetCalendarStartToPreviousWeek"><i class="bi bi-chevron-double-up"></i></button>
            <button class="btn btn-outline-primary" aria-label="@Loc["Previous month"]" @onclick="() => _calendarParams.SetCalendarStartToPreviousMonth(ClientState.Settings.FirstDayOfWeek)"><i class="bi bi-chevron-double-left"></i></button>
            <span class="input-group-text flex-grow-1" style="justify-content: center;">@_calendarParams.FirstDayOfMonth.ToString("MMMM")</span>
            <button class="btn btn-outline-primary" aria-label="@Loc["Next month"]" @onclick="() => _calendarParams.SetCalendarStartToNextMonth(ClientState.Settings.FirstDayOfWeek)"><i class="bi bi-chevron-double-right"></i></button>
            <button class="btn btn-outline-primary" aria-label="@Loc["Next week"]" @onclick="_calendarParams.SetCalendarStartToNextWeek"><i class="bi bi-chevron-double-down"></i></button>
        </div>
    }

    <div role="grid" aria-label="@Loc["Calendar"]" @onkeydown="HandleGridKeyDown" @ref="_gridRef">
        @if (DisplayMonth)
        {
            <div class="bg-body d-flex" role="row">
                @for (int i = 0; i < 7; i++)
                {
                    int dayIdx = OpenHabitTracker.Services.CalendarService.GetDayOfWeek(ClientState.Settings.FirstDayOfWeek, i);
                    string day = Loc[_days[dayIdx]];
                    <div @key="day" class="border d-flex" role="columnheader" scope="col" style="align-items: center; justify-content: center; height: 50px; width: 50px">@day</div>
                }
            </div>
        }

        @for (int row = 0; row < rowCount; row++)
        {
            <div class="d-flex" role="row">
                @for (int day = 0; day < daysInRow; day++)
                {
                    int cellIndex = row * daysInRow + day;
                    DateTime dateTime = CalendarService.GetCalendarDay(_calendarParams.CalendarStart, cellIndex); // if not captured locally, day becomes the last value used in the loop

                    string text = dateTime.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday ? "text-warning" : "text-secondary";
                    if (dateTime.Month == _calendarParams.FirstDayOfMonth.Month)
                        text += "-emphasis";
                    string border = dateTime == selectedDateTime ? "border-4 border-success-subtle" : dateTime.Date == DateTime.Today ? "border-4 border-primary-subtle" : "";
                    string background = "bg-body-tertiary";
                    string timesDone = "";
                    List<TimeModel>? list = null;

                    if (Habit.TimesDoneByDay.TryGetValue(dateTime, out list) && list.Count > 0)
                    {
                        if (list.Count > 1)
                            timesDone = $"({list.Count})";

                        if ((Habit.RepeatPeriod == Period.Day && list.Count >= Habit.RepeatCount) || (Habit.RepeatPeriod != Period.Day && Habit.RepeatCountReached(dateTime)))
                            background = "bg-success-subtle";
                        else
                            background = "bg-warning-subtle";
                    }

                    string ariaLabel = $"{dateTime:dddd, MMMM d} \u2014 {list?.Count ?? 0} {Loc["times done"]}";

                    <button class="@($"border {border} {text} d-flex {background}")"
                            role="gridcell"
                            style="align-items: center; justify-content: center; height: 50px; width: 50px; line-height: normal; flex-direction: column;"
                            tabindex="@(cellIndex == _activeDayIndex ? 0 : -1)"
                            @ref="_dayCellRefs[cellIndex]"
                            aria-label="@ariaLabel"
                            @onclick="() => DayClicked(dateTime, list, cellIndex)">
                        @dateTime.Day<small>@timesDone</small>
                    </button>
                }
            </div>
        }
    </div>

    if (selectedDateTime is not null)
    {
        <div class="input-group mt-1">
            <button class="btn btn-outline-primary" aria-label="@Loc["Decrease"]" @onclick="RemoveFromSelectedDay"><i class="bi bi-dash"></i></button>
            <span class="input-group-text flex-grow-1" style="justify-content: center;">@(selectedTimeList?.Count ?? 0)</span>
            <button class="btn btn-outline-primary" aria-label="@Loc["Increase"]" @onclick="AddToSelectedDay"><i class="bi bi-plus"></i></button>
        </div>

        if (DisplayTimeList && selectedTimeList is not null)
        {
            foreach (TimeModel time in selectedTimeList)
            {
                <div class="input-group">
                    <span class="input-group-text">@Loc["From"]</span>
                    <InputDate class="form-control" aria-label="@Loc["From"]" Type="InputDateType.Time" Value="time.StartedAt" ValueExpression="() => time.StartedAt" ValueChanged="(DateTime startedAt) => UpdateStartedAt(time, startedAt)" />
                    <span class="input-group-text">@Loc["to"]</span>
                    <InputDate class="form-control" aria-label="@Loc["to"]" Type="InputDateType.Time" Value="time.CompletedAt" ValueExpression="() => time.CompletedAt" ValueChanged="(DateTime? completedAt) => UpdateCompletedAt(time, completedAt)" />
                    <button class="btn btn-outline-primary" aria-label="@Loc["Delete"]" @onclick="() => RemoveTimeDone(time)"><i class="bi bi-trash"></i></button>
                </div>
            }
        }
    }
}

@code {
    [EditorRequired]
    [Parameter]
    public HabitModel? Habit { get; set; }

    [EditorRequired]
    [Parameter]
    public EventCallback<HabitModel?> HabitChanged { get; set; }

    [Parameter]
    public bool DisplayMonth { get; set; }

    [Parameter]
    public bool DisplayBasedOnWidth { get; set; }

    [Parameter]
    public bool DisplayTimeList { get; set; }

    int rowCount = 0;
    int daysInRow = 0;

    [Parameter]
    public int ColumnWidth { get; set; }

    int _currentColumnWidth;

    CalendarParams _calendarParams = new();

    private readonly string[] _days = { "Su", "Mo", "Tu", "We", "Th", "Fr", "Sa" };

    int _activeDayIndex = 0;
    ElementReference[] _dayCellRefs = Array.Empty<ElementReference>();
    ElementReference _gridRef;

    protected override async Task OnParametersSetAsync()
    {
        if (_calendarParams.CalendarStart == DateTime.MinValue || _calendarParams.CalendarStart.DayOfWeek != ClientState.Settings.FirstDayOfWeek)
        {
            if (DisplayMonth)
            {
                rowCount = 6;
                daysInRow = 7;
                _calendarParams.SetCalendarStartByFirstDayOfMonth(ClientState.Settings.FirstDayOfWeek, DateTime.Today);
            }
        }

        if (ColumnWidth != 0 && (_currentColumnWidth != ColumnWidth || rowCount == 0))
        {
            _currentColumnWidth = ColumnWidth;

            if (DisplayBasedOnWidth)
            {
                rowCount = 1;
                daysInRow = (ColumnWidth-350) / 50;
                _calendarParams.SetCalendarStartByDaysFromToday(-daysInRow + 1);
            }
            else
            {
                rowCount = 1;
                daysInRow = ColumnWidth / 50;
                _calendarParams.SetCalendarStartByDaysFromToday(-daysInRow + 1);
                //_calendarParams.SetCalendarStartByFirstDayOfWeek(ClientState.Settings.FirstDayOfWeek, DateTime.Today);
            }
        }

        int totalCells = rowCount * daysInRow;
        if (_dayCellRefs.Length != totalCells)
        {
            _dayCellRefs = new ElementReference[totalCells];
            _activeDayIndex = 0;
        }

        if (Habit is not null)
        {
            if (Habit.TimesDoneByDay is null)
                await HabitService.LoadTimesDone(Habit);

            if (Habit.TimesDoneByDay is not null && selectedDateTime.HasValue)
            {
                if (!Habit.TimesDoneByDay.TryGetValue(selectedDateTime.Value, out selectedTimeList))
                    selectedDateTime = null;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JsInterop.PreventScrollKeys(_gridRef);
    }

    DateTime? selectedDateTime;
    List<TimeModel>? selectedTimeList;

    async Task RemoveFromSelectedDay()
    {
        await RemoveTimeDone(selectedTimeList);
    }

    async Task AddToSelectedDay()
    {
        await AddTimeDone(selectedDateTime!.Value);

        if (selectedTimeList is null)
            Habit!.TimesDoneByDay!.TryGetValue(selectedDateTime!.Value, out selectedTimeList);
    }

    async Task HandleGridKeyDown(KeyboardEventArgs e)
    {
        int totalCells = rowCount * daysInRow;
        switch (e.Key)
        {
            case "ArrowRight":
                if (_activeDayIndex + 1 < totalCells)
                    _activeDayIndex++;
                else
                {
                    if (DisplayMonth)
                        _calendarParams.SetCalendarStartToNextMonth(ClientState.Settings.FirstDayOfWeek);
                    else
                        _calendarParams.SetCalendarStartToNextWeek();
                    _activeDayIndex = 0;
                }
                break;
            case "ArrowLeft":
                if (_activeDayIndex - 1 >= 0)
                    _activeDayIndex--;
                else
                {
                    if (DisplayMonth)
                        _calendarParams.SetCalendarStartToPreviousMonth(ClientState.Settings.FirstDayOfWeek);
                    else
                        _calendarParams.SetCalendarStartToPreviousWeek();
                    _activeDayIndex = totalCells - 1;
                }
                break;
            case "ArrowDown":
                if (_activeDayIndex + daysInRow < totalCells)
                    _activeDayIndex += daysInRow;
                else
                {
                    if (DisplayMonth)
                        _calendarParams.SetCalendarStartToNextMonth(ClientState.Settings.FirstDayOfWeek);
                    else
                        _calendarParams.SetCalendarStartToNextWeek();
                    _activeDayIndex = 0;
                }
                break;
            case "ArrowUp":
                if (_activeDayIndex - daysInRow >= 0)
                    _activeDayIndex -= daysInRow;
                else
                {
                    if (DisplayMonth)
                        _calendarParams.SetCalendarStartToPreviousMonth(ClientState.Settings.FirstDayOfWeek);
                    else
                        _calendarParams.SetCalendarStartToPreviousWeek();
                    _activeDayIndex = totalCells - 1;
                }
                break;
            case "Home":
                _activeDayIndex = (_activeDayIndex / daysInRow) * daysInRow;
                break;
            case "End":
                _activeDayIndex = (_activeDayIndex / daysInRow) * daysInRow + daysInRow - 1;
                break;
            case "PageDown":
                if (DisplayMonth)
                    _calendarParams.SetCalendarStartToNextMonth(ClientState.Settings.FirstDayOfWeek);
                else
                    _calendarParams.SetCalendarStartToNextWeek();
                _activeDayIndex = 0;
                break;
            case "PageUp":
                if (DisplayMonth)
                    _calendarParams.SetCalendarStartToPreviousMonth(ClientState.Settings.FirstDayOfWeek);
                else
                    _calendarParams.SetCalendarStartToPreviousWeek();
                _activeDayIndex = 0;
                break;
            default:
                return;
        }
        await JsInterop.FocusElement(_dayCellRefs[_activeDayIndex]);
    }

    async Task DayClicked(DateTime dateTime, List<TimeModel>? timeList, int cellIndex)
    {
        _activeDayIndex = cellIndex;
        if (DisplayMonth)
        {
            if (selectedDateTime == dateTime)
            {
                selectedDateTime = null;
            }
            else
            {
                selectedDateTime = dateTime;
                selectedTimeList = timeList;
            }
        }
        else
        {
            await AddTimeDone(dateTime);
        }
    }

    async Task AddTimeDone(DateTime dateTime)
    {
        if (dateTime > DateTime.Now)
            return;

        if (dateTime.Date == DateTime.Today)
            dateTime = DateTime.Now;
        else if (dateTime.TimeOfDay == TimeSpan.Zero)
            dateTime = dateTime.AddHours(12);

        await HabitService.AddTimeDone(Habit!, dateTime);

        await HabitChanged.InvokeAsync(Habit);
    }

    async Task RemoveTimeDone(List<TimeModel>? timeList)
    {
        if (timeList is null || timeList.Count == 0)
            return;

        await HabitService.RemoveTimeDone(Habit!, timeList.Last());

        await HabitChanged.InvokeAsync(Habit);
    }

    async Task RemoveTimeDone(TimeModel time)
    {
        await HabitService.RemoveTimeDone(Habit!, time);

        await HabitChanged.InvokeAsync(Habit);
    }

    async Task UpdateStartedAt(TimeModel time, DateTime startedAt)
    {
        if (startedAt.TimeOfDay <= time.CompletedAt?.TimeOfDay)
        {
            time.StartedAt = time.StartedAt.Date + startedAt.TimeOfDay;

            await HabitService.UpdateTimeDone(Habit!, time);

            await HabitChanged.InvokeAsync(Habit);
        }
    }

    async Task UpdateCompletedAt(TimeModel time, DateTime? completedAt)
    {
        if (completedAt?.TimeOfDay >= time.StartedAt.TimeOfDay)
        {
            time.CompletedAt = time.CompletedAt?.Date + completedAt?.TimeOfDay;

            await HabitService.UpdateTimeDone(Habit!, time);

            await HabitChanged.InvokeAsync(Habit);
        }
    }
}
