@using OpenHabitTracker.App
@using OpenHabitTracker.Data
@using OpenHabitTracker.Data.Models
@using OpenHabitTracker.Services

@inject IHabitService HabitService
@inject ClientState ClientState
@inject IStringLocalizer Loc

@if (_loaded && HabitService.Habits is not null)
{
    DateTime weekStart = CalendarParams.GetFirstDayOfWeek(ClientState.Settings.FirstDayOfWeek, DateTime.Today);
    DateTime weekEnd = weekStart.AddDays(7);

    List<HabitModel> habits = HabitService.GetHabits().ToList();
    int total = habits.Count;
    int green = habits.Count(h => h.GetRatio(ClientState.Settings.SelectedRatio) < 80);
    int orange = habits.Count(h => { double r = h.GetRatio(ClientState.Settings.SelectedRatio); return r >= 80 && r < 100; });
    int red = habits.Count(h => h.GetRatio(ClientState.Settings.SelectedRatio) >= 100);
    int doneThisWeek = habits.Count(h => h.TimesDone?.Any(t => t.StartedAt >= weekStart && t.StartedAt < weekEnd) == true);
    DateTime? lastDone = habits.Where(h => h.LastTimeDoneAt is not null).Select(h => h.LastTimeDoneAt).Max();

    @if (total > 0)
    {
    <div class="p-2">
        <p class="fw-bold mb-1">@Loc["This week"] (@weekStart.ToShortDateString() – @weekStart.AddDays(6).ToShortDateString())</p>
        <p class="mb-1">@doneThisWeek @Loc["out of"] @total @Loc["done"]</p>

        <div class="d-flex gap-2 mb-2">
            <span class="badge bg-success-subtle text-success-emphasis">@green</span>
            <span class="badge bg-warning-subtle text-warning-emphasis">@orange</span>
            <span class="badge bg-danger-subtle text-danger-emphasis">@red</span>
        </div>

        @if (lastDone is not null)
        {
            <p class="mb-0">@Loc["Last done"]: @lastDone.Value.ToShortDateString() @lastDone.Value.ToString("HH:mm")</p>
        }
    </div>
    }
}

@code {
    bool _loaded;

    [CascadingParameter(Name = "StateChanged")]
    public bool StateChanged { get; set; }

    [Parameter]
    public bool PageStateChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await HabitService.LoadAllTimesDone();
        _loaded = true;
    }

}
