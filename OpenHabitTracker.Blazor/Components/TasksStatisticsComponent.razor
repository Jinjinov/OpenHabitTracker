@using OpenHabitTracker.App
@using OpenHabitTracker.Data
@using OpenHabitTracker.Data.Models
@using OpenHabitTracker.Services

@inject ITaskService TaskService
@inject ClientState ClientState
@inject IStringLocalizer Loc

@if (TaskService.Tasks is not null)
{
    DateTime weekStart = CalendarParams.GetFirstDayOfWeek(ClientState.Settings.FirstDayOfWeek, DateTime.Today);

    List<TaskModel> tasks = TaskService.GetTasks().ToList();
    int total = tasks.Count;
    int done = tasks.Count(t => t.CompletedAt is not null);
    int overdue = tasks.Count(t => t.PlannedAt < DateTime.Now && t.CompletedAt is null);
    int completedThisWeek = tasks.Count(t => t.CompletedAt >= weekStart && t.CompletedAt < weekStart.AddDays(7));
    int plannedThisWeek = tasks.Count(t => t.PlannedAt >= weekStart && t.PlannedAt < weekStart.AddDays(7));
    TimeSpan totalTimeSpent = TimeSpan.FromTicks(tasks
        .Where(t => t.CompletedAt is not null && t.StartedAt is not null && t.CompletedAt > t.StartedAt)
        .Sum(t => (t.CompletedAt!.Value - t.StartedAt!.Value).Ticks));

    @if (total > 0)
    {
    <div class="p-2">
        <p class="fw-bold mb-1">@Loc["This week"] (@weekStart.ToShortDateString() – @weekStart.AddDays(6).ToShortDateString())</p>
        <p class="mb-1">@completedThisWeek @Loc["done"] · @plannedThisWeek @Loc["planned"]</p>

        <div class="d-flex gap-2 mb-2">
            <span class="badge bg-body-secondary">@Loc["Total"]: @total</span>
            <span class="badge bg-success-subtle text-success-emphasis">@Loc["Done"]: @done</span>
            <span class="badge bg-danger-subtle text-danger-emphasis">@Loc["Overdue"]: @overdue</span>
        </div>

        @if (totalTimeSpent > TimeSpan.Zero)
        {
            <p class="mb-0">@Loc["Total time spent"]: @FormatTimeSpan(totalTimeSpent)</p>
        }
    </div>
    }
}

@code {
    [CascadingParameter(Name = "StateChanged")]
    public bool StateChanged { get; set; }

    string FormatTimeSpan(TimeSpan span)
    {
        if (span.TotalHours >= 1)
            return $"{(int)span.TotalHours}h {span.Minutes}m";

        return $"{span.Minutes}m";
    }
}
