@page "/notes"
@page "/notes/{Id:long}"

@using GTour.Abstractions
@using OpenHabitTracker.App
@using OpenHabitTracker.Data
@using OpenHabitTracker.Data.Models
@using OpenHabitTracker.Query
@using OpenHabitTracker.Services
@using Microsoft.JSInterop

@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject INoteService NoteService
@inject ICategoryService CategoryService
@inject ClientState ClientState
@inject IJsInterop JsInterop
@inject ISearchFilterService SearchFilterService
@inject IStringLocalizer Loc
@inject IPriorityService PriorityService
@inject IGTourService GTourService

<PageTitle>OpenHabitTracker - Notes</PageTitle>

<div class="@($"col child-column px-0 px-md-{ClientState.Settings.HorizontalMargin}")">

    @if (NoteService.NewNote is null)
    {
        <button class="btn btn-plain input-group d-flex flex-nowrap my-1 p-0" @onclick="AddNew">
            <span class="input-group-text fw-bold text-primary flex-grow-1">@Loc["Add new note"]</span>

            <span class="btn btn-outline-primary"><i class="bi bi-plus-square" aria-hidden="true"></i></span>
        </button>
    }
    @if (NoteService.NewNote is not null)
    {
        <div class="@($"my-1 {NoteService.NewNote.Color}")">
            <div class="input-group">
                @if (ClientState.Settings.ShowPriorityDropdown)
                {
                    <PriorityComponent Model="NoteService.NewNote" />
                }

                <InputTextImmediate class="form-control" @ref="inputElement" @bind-Value="NoteService.NewNote.Title" placeholder="@Loc["Add new note"]" aria-label="@Loc["Note title"]" aria-required="true" />

                <button class="btn btn-outline-primary" aria-label="@Loc["Save"]" @onclick="OnAddNote" disabled="@string.IsNullOrWhiteSpace(NoteService.NewNote.Title)"><i class="bi bi-floppy"></i></button>
                <button class="btn btn-outline-primary" aria-label="@Loc["Close"]" @onclick="() => NoteService.NewNote = null"><i class="bi bi-x-square"></i></button>
            </div>

            <InputTextArea @ref="_inputTextAreaReference" class="form-control" style="resize:none" @bind-Value="NoteService.NewNote.Content" placeholder="@Loc["Add note text"]" aria-label="@Loc["Add note text"]" />

            @if (ClientState.Settings.ShowCategory)
            {
                <div class="input-group flex-nowrap">
                    <span class="input-group-text bg-transparent col-4">@Loc["Category"]</span>
                    <CategoryComponent Model="NoteService.NewNote" />
                </div>
            }

            @if (ClientState.Settings.ShowColor)
            {
                <div class="input-group flex-nowrap">
                    <span class="input-group-text bg-transparent col-4">@Loc["Color"]</span>
                    <ColorComponent Model="NoteService.NewNote" />
                </div>
            }
        </div>
    }

    @if (NoteService.Notes is not null)
    {
        <div class="d-grid align-items-center" style="grid-template-columns: 1fr auto 1fr;">
            <div></div>

            <div class="m-2 fs-4"><i class="bi bi-sticky" aria-hidden="true"></i> @Loc["Notes"]</div>

            @if (ClientState.Settings.ShowHelp)
            {
                <button class="btn btn-plain ms-auto m-1" aria-label="@Loc["Help"]" @onclick="@(() => StartTour("notes"))"><i class="bi bi-question-circle"></i></button>
            }
        </div>

        foreach (var group in GetNoteGroups())
        {
            @if (ClientState.Settings.ShowGroupedByCategory)
            {
                string categoryTitle = group.Category?.Title ?? Loc["Uncategorized"];
                string? foldIcon = group.Category == null ? null : group.Category.IsCollapsed ? "bi-chevron-right" : "bi-chevron-down";
                <button class="btn btn-plain border-0 p-0 text-start my-2 w-100" @onclick="() => OnToggleCollapsed(group.Category)">
                    <small><i class="bi bi-tag" aria-hidden="true"></i> @categoryTitle@if (foldIcon != null) {<i class="@($"bi {foldIcon} mx-1")" aria-hidden="true"></i>}</small>
                </button>
            }

            @if (group.Category?.IsCollapsed != true)
            {
            foreach (NoteModel note in group.Notes)
            {
                <div class="@($"my-{ClientState.Settings.VerticalMargin}")">
                    @if (!_showSecondColumn && note.Id == Id && NoteService.NewNote is null)
                    {
                        <NoteComponent Note="note" CloseSelected="CloseSelected" />
                    }
                    else
                    {
                        <div class="@note.Color">
                            <div class="input-group flex-nowrap">

                                @if (ClientState.Settings.ShowPriorityDropdown)
                                {
                                    <span class="input-group-text bg-transparent" data-notes-step-1>@PriorityService.GetPriorityTitle(note.Priority)</span>
                                }

                                <button id="note-item-@note.Id" class="input-group-text bg-transparent flex-grow-1 text-wrap highlightable" @onclick="() => OpenSelected(note.Id)" data-notes-step-2>@((MarkupString)SearchFilterService.MarkSearchResults(note.Title))</button>
                            </div>

                            @if (ClientState.Settings.DisplayNoteContentAsMarkdown)
                            {
                                <div class="form-control bg-transparent markdown-block-margin" style="min-height: 38px;" data-notes-step-3>@((MarkupString)SearchFilterService.MarkSearchResultsInHtml(note.ContentMarkdown))</div>
                            }
                            else
                            {
                                <div class="form-control bg-transparent" style="white-space: pre-wrap; min-height: 38px;" data-notes-step-3>@((MarkupString)SearchFilterService.MarkSearchResults(note.Content))</div>
                            }
                        </div>
                    }
                </div>
            }
            }
        }
    }

    @if (ClientState.Settings.ShowHelp)
    {
        <GuidedTourComponent TourId="notes" TourSteps="tourSteps" />
    }

    @if (!_showSecondColumn)
    {
        <NotesStatisticsComponent PageStateChanged="_pageStateChanged" />
    }

</div>

@if (_showSecondColumn)
{
    <div class="col child-column px-0 px-md-1 py-1">
        @if (_showNoteComponent)
        {
            <NoteComponent Note="NoteService.SelectedNote" CloseSelected="CloseSelected" />
        }
        else
        {
            <NotesStatisticsComponent PageStateChanged="_pageStateChanged" />
        }
    </div>
}

@code {
    TourStep[] tourSteps;

    public Notes()
    {
        tourSteps = new TourStep[]
        {
            new() { Text = "Note's priority." },
            new() { Text = "Note's title." },
            new() { Text = "Note's content." },
            new() { Text = "Set the note's priority.", Show = () => _showNoteComponent },
            new() { Text = "Change the note's title.", Show = () => _showNoteComponent },
            new() { Text = "Delete the note.", Show = () => _showNoteComponent },
            new() { Text = "Close the note.", Show = () => _showNoteComponent },
            new() { Text = "Change the note's content.", Show = () => _showNoteComponent },
            new() { Text = "Set the note's category.", Show = () => _showNoteComponent },
            new() { Text = "Set the note's color.", Show = () => _showNoteComponent && ClientState.Settings.ShowColor },
            new() { Text = "The date when the note was created and the date when the note was last updated.", Show = () => _showNoteComponent && ClientState.Settings.ShowCreatedUpdated },
        };
    }

    private async Task StartTour(string tourId)
    {
        await GTourService.StartTour(tourId);
    }

    [Parameter]
    public long? Id { get; set; }

    [Parameter]
    public bool IsEmbedded { get; set; }

    [Parameter]
    public bool IsCollapsedChanged { get; set; }

    [Parameter]
    public EventCallback OnIsCollapsedChanged { get; set; }

    [CascadingParameter(Name = "StateChanged")]
    public bool StateChanged { get; set; }

    [CascadingParameter(Name = "WindowDimensions")]
    public Dimensions? WindowDimensions { get; set; }

    bool _showSecondColumn => !IsEmbedded && WindowDimensions?.Width >= 1280;

    bool _showNoteComponent => Id is not null && NoteService.SelectedNote is not null && NoteService.NewNote is null;

    InputTextImmediate? inputElement;

    bool shouldFocus;
    bool _shouldFocusEdit;
    bool _prevShowNoteComponent;
    long _lastSelectedId;
    bool _pageStateChanged;

    InputTextArea? _inputTextAreaReference;

    protected override async Task OnInitializedAsync()
    {
        await NoteService.Initialize();
    }

    protected override void OnParametersSet()
    {
        NoteService.SetSelectedNote(Id);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldFocus && inputElement?.Element is not null)
        {
            shouldFocus = false;
            await inputElement.Element.Value.FocusAsync();
        }

        if (_inputTextAreaReference?.Element is not null)
        {
            if (ClientState.Settings.InsertTabsInNoteContent)
                await JsInterop.HandleTabKey(_inputTextAreaReference.Element.Value);

            await JsInterop.SetCalculateAutoHeight(_inputTextAreaReference.Element.Value);
        }

        bool editOpened = !_prevShowNoteComponent && _showNoteComponent;
        bool editClosed = _prevShowNoteComponent && !_showNoteComponent;
        _prevShowNoteComponent = _showNoteComponent;

        if (_shouldFocusEdit && editOpened)
        {
            _shouldFocusEdit = false;
            await JsInterop.FocusFirstIn("#note-component");
        }
        else if (editClosed && _lastSelectedId != 0)
        {
            await JsInterop.FocusElementById($"note-item-{_lastSelectedId}");
        }
    }

    IEnumerable<(CategoryModel? Category, IEnumerable<NoteModel> Notes)> GetNoteGroups()
    {
        if (!ClientState.Settings.ShowGroupedByCategory || CategoryService.Categories is null)
        {
            yield return (null, NoteService.GetNotes());
            yield break;
        }

        QueryParameters queryParameters = SearchFilterService.GetQueryParameters(ClientState.Settings);

        foreach (CategoryModel category in CategoryService.Categories)
        {
            if (ClientState.Settings.CategoryFilterDisplay == FilterDisplay.CheckBoxes || ClientState.Settings.CategoryFilterDisplay == FilterDisplay.RadioButtons)
            {
                if (ClientState.Settings.HiddenCategoryIds.Contains(category.Id))
                    continue;
            }
            else if (ClientState.Settings.CategoryFilterDisplay == FilterDisplay.SelectOptions)
            {
                if (ClientState.Settings.SelectedCategoryId is not null && ClientState.Settings.SelectedCategoryId != category.Id)
                    continue;
            }

            List<NoteModel> notes = category.Notes.FilterNotes(queryParameters).ToList();
            if (notes.Count > 0)
                yield return (category, notes);
        }

        List<NoteModel> uncategorized = ClientState.Notes!.Values.Where(x => x.CategoryId == 0).FilterNotes(queryParameters).ToList();
        if (uncategorized.Count > 0)
            yield return (null, uncategorized);
    }

    async Task OnToggleCollapsed(CategoryModel? category)
    {
        if (category is not null)
        {
            await CategoryService.ToggleCollapsed(category);
            await OnIsCollapsedChanged.InvokeAsync();
        }
    }

    async Task OnAddNote()
    {
        await NoteService.AddNote();
        _pageStateChanged = !_pageStateChanged;
    }

    void AddNew()
    {
        NoteService.NewNote = new() { Color = "bg-info-subtle" };
        shouldFocus = true;
    }

    async Task OpenSelected(long id)
    {
        _lastSelectedId = id;
        _shouldFocusEdit = true;
        if (IsEmbedded)
        {
            Id = id;
            NoteService.SetSelectedNote(Id);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("skipNextScrollTo");

            NavigationManager.NavigateTo($"/notes/{id}");
        }
    }

    async Task CloseSelected()
    {
        _pageStateChanged = !_pageStateChanged;

        if (IsEmbedded)
        {
            Id = null;
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("skipNextScrollTo");

            NavigationManager.NavigateTo("/notes");
        }
    }
}
