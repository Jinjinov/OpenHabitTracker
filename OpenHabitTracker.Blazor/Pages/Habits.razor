@page "/habits"
@page "/habits/{Id:long}"

@using GTour.Abstractions
@using OpenHabitTracker.App
@using OpenHabitTracker.Data
@using OpenHabitTracker.Data.Models
@using OpenHabitTracker.Query
@using OpenHabitTracker.Services
@using Microsoft.JSInterop

@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject IHabitService HabitService
@inject ICategoryService CategoryService
@inject ClientState ClientState
@inject IJsInterop JsInterop
@inject ISearchFilterService SearchFilterService
@inject IStringLocalizer Loc
@inject IPriorityService PriorityService
@inject IGTourService GTourService

<PageTitle>OpenHabitTracker - Habits</PageTitle>

<div @ref="columnRef" class="@($"col child-column px-0 px-md-{ClientState.Settings.HorizontalMargin}")">

    @if (HabitService.NewHabit is null)
    {
        <button class="btn btn-plain input-group d-flex flex-nowrap my-1 p-0" @onclick="AddNew">
            <span class="input-group-text fw-bold text-primary flex-grow-1">@Loc["Add new habit"]</span>

            <span class="btn btn-outline-primary"><i class="bi bi-plus-square" aria-hidden="true"></i></span>
        </button>
    }
    @if (HabitService.NewHabit is not null)
    {
        <div class="@($"my-1 {HabitService.NewHabit.Color}")">
            <div class="input-group">
                @if (ClientState.Settings.ShowPriorityDropdown)
                {
                    <PriorityComponent Model="HabitService.NewHabit" />
                }

                <InputTextImmediate class="form-control" @ref="inputElement" @bind-Value="HabitService.NewHabit.Title" placeholder="@Loc["Add new habit"]" aria-label="@Loc["Habit title"]" aria-required="true" />

                <button class="btn btn-outline-primary" aria-label="@Loc["Save"]" @onclick="OnAddHabit" disabled="@string.IsNullOrWhiteSpace(HabitService.NewHabit.Title)"><i class="bi bi-floppy"></i></button>
                <button class="btn btn-outline-primary" aria-label="@Loc["Close"]" @onclick="() => HabitService.NewHabit = null"><i class="bi bi-x-square"></i></button>
            </div>

            <div class="input-group">
                <label class="input-group-text bg-transparent" for="countInput">@Loc["Repeat"]</label>
                <InputNumber class="form-control" id="countInput" @bind-Value="HabitService.NewHabit.RepeatCount" />

                <label class="input-group-text bg-transparent" for="intervalInput">@Loc["every"]</label>
                <InputNumber class="form-control" id="intervalInput" @bind-Value="HabitService.NewHabit.RepeatInterval" />

                <InputSelect class="form-select" aria-label="@Loc["Repeat period"]" @bind-Value="HabitService.NewHabit.RepeatPeriod">
                    @foreach (Period period in Enum.GetValues<Period>())
                    {
                        <option value="@period">@Loc[period.ToString()]</option>
                    }
                </InputSelect>
            </div>

            <div class="input-group">
                <span class="input-group-text bg-transparent">@Loc["Duration"]</span>

                <InputSelect class="form-select" aria-label="@Loc["Duration hours"]" @bind-Value="HabitService.NewHabit.DurationHour" TValue="int">
                    @for (int i = 0; i <= 23; i++)
                    {
                        <option value="@i">@i</option>
                    }
                </InputSelect>
                <span class="input-group-text bg-transparent">h</span>

                <InputSelect class="form-select" aria-label="@Loc["Duration minutes"]" @bind-Value="HabitService.NewHabit.DurationMinute" TValue="int">
                    @for (int i = 0; i <= 59; i++)
                    {
                        <option value="@i">@i</option>
                    }
                </InputSelect>
                <span class="input-group-text bg-transparent">min</span>
            </div>

            @if (ClientState.Settings.ShowCategory)
            {
                <div class="input-group flex-nowrap">
                    <span class="input-group-text bg-transparent col-4">@Loc["Category"]</span>
                    <CategoryComponent Model="HabitService.NewHabit" />
                </div>
            }

            @if (ClientState.Settings.ShowColor)
            {
                <div class="input-group flex-nowrap">
                    <span class="input-group-text bg-transparent col-4">@Loc["Color"]</span>
                    <ColorComponent Model="HabitService.NewHabit" />
                </div>
            }
        </div>
    }

    @if (HabitService.Habits is not null && columnWidth != 0)
    {
        <div class="d-grid align-items-center" style="grid-template-columns: 1fr auto 1fr;">
            <div></div>

            <div class="m-2 fs-4"><i class="bi bi-repeat" aria-hidden="true"></i> @Loc["Habits"]</div>

            @if (ClientState.Settings.ShowHelp)
            {
                <button class="btn btn-plain ms-auto m-1" aria-label="@Loc["Help"]" @onclick="@(() => StartTour("habits"))"><i class="bi bi-question-circle"></i></button>
            }
        </div>

        DateTime weekStart = CalendarParams.GetFirstDayOfWeek(ClientState.Settings.FirstDayOfWeek, DateTime.Today);
        DateTime weekEnd = weekStart.AddDays(7);

        foreach (var group in GetHabitGroups())
        {
            @if (ClientState.Settings.ShowGroupedByCategory)
            {
                string categoryTitle = group.Category?.Title ?? Loc["Uncategorized"];
                string foldIcon = group.Category?.IsCollapsed == true ? "bi-chevron-right" : "bi-chevron-down";
                DateTime? categoryLastDone = group.Habits.Max(h => h.LastTimeDoneAt);
                int habitCount = group.Habits.Count();
                int doneThisWeek = group.Habits.Count(h => h.TimesDone?.Any(t => t.StartedAt >= weekStart && t.StartedAt < weekEnd) == true);
                string completionColor = GetCompletionColor(group.Category?.CompletionRule ?? CompletionRule.All, doneThisWeek, habitCount);
                <button class="btn btn-plain border-0 p-0 text-start my-2 w-100" @onclick="() => OnToggleCollapsed(group.Category)">
                    <small class="d-block"><i class="bi bi-tag" aria-hidden="true"></i> @categoryTitle<i class="@($"bi {foldIcon} mx-1")" aria-hidden="true"></i></small>
                </button>
                @if (group.Category is not null)
                {
                    <small class="d-flex align-items-center gap-1"><span>@Loc["Mark complete when"]</span> <button class="btn btn-outline-@completionColor btn-sm py-0 px-1" aria-pressed="@(group.Category.CompletionRule == CompletionRule.All)" @onclick="() => OnToggleCompletionRule(group.Category)">@Loc[group.Category.CompletionRule == CompletionRule.All ? "all habits are done" : "any habit is done"]</button></small>
                }
                @if (ClientState.Settings.ShowLastTimeDone && categoryLastDone is not null && group.Category?.IsCollapsed != true)
                {
                    <small class="d-block">@Loc["Last done"]: @($"{categoryLastDone.Value.ToShortDateString()} {categoryLastDone.Value:HH:mm}")</small>
                }
            }

            @if (group.Category?.IsCollapsed != true)
            {
            foreach (HabitModel habit in group.Habits)
            {
                bool showHabitComponent = !_showSecondColumn && habit.Id == Id && HabitService.NewHabit is null;

                <div class="@($"my-{ClientState.Settings.VerticalMargin} {(showHabitComponent ? "" : "d-flex")}")">
                    @if (showHabitComponent)
                    {
                        <HabitComponent Habit="habit" CloseSelected="CloseSelected" />
                    }
                    else
                    {
                        <div class="@($"w-100 {habit.Color}")">
                            <div class="input-group flex-nowrap" style="@($"{(_displayBasedOnWidth && ClientState.Settings.ShowSmallCalendar ? "height: 50px;" : "")}")">

                                @if (ClientState.Settings.ShowPriorityDropdown)
                                {
                                    <span class="input-group-text bg-transparent" data-habits-step-1>@PriorityService.GetPriorityTitle(habit.Priority)</span>
                                }

                                <button id="habit-item-@habit.Id" class="input-group-text bg-transparent flex-grow-1 text-wrap highlightable" @onclick="() => OpenSelected(habit.Id)" data-habits-step-2>@((MarkupString)SearchFilterService.MarkSearchResults(habit.Title))</button>

                                @{
                                    string color = habit.GetRatio(ClientState.Settings.SelectedRatio) switch
                                    {
                                        >= 100 => "bg-danger-subtle",
                                        >= 80 => "bg-warning-subtle",
                                        _ => "bg-success-subtle"
                                    };
                                }
                                <small class="@($"input-group-text {color}")" data-habits-step-3>
                                    @(habit.LastTimeDoneAt is not null ? ToHighestValueString(habit.ElapsedTime) : "⊘")
                                    (@habit.GetRatio(ClientState.Settings.SelectedRatio).ToString("N0")%)
                                </small>

                                @if (!ClientState.Settings.ShowSmallCalendar)
                                {
                                    <button class="btn btn-outline-primary" aria-label="@Loc["Mark as done"]" @onclick="() => OnMarkAsDone(habit)" data-habits-step-4><i class="bi bi-check-square"></i></button>
                                }
                            </div>

                            @if (ClientState.Settings.ShowItemList)
                            {
                                <div data-habits-step-5>
                                    <ItemsComponent Items=habit IsReadOnly=true />
                                </div>
                            }

                            @if (!_displayBasedOnWidth && ClientState.Settings.ShowSmallCalendar)
                            {
                                <div class="input-group-text bg-transparent p-0 border-0 rounded-0" data-habits-step-6>
                                    <div class="mx-auto">
                                        <CalendarComponent Habit="habit" HabitChanged="OnHabitChanged" ColumnWidth="columnWidth" />
                                    </div>
                                </div>
                            }

                        </div>
                        if (_displayBasedOnWidth && ClientState.Settings.ShowSmallCalendar)
                        {
                            <div class="d-flex" data-habits-step-6>
                                <CalendarComponent Habit="habit" HabitChanged="OnHabitChanged" ColumnWidth="columnWidth" DisplayBasedOnWidth />
                            </div>
                        }
                    }
                </div>
            }
            }
        }
    }

    @if (ClientState.Settings.ShowHelp)
    {
        <GuidedTourComponent TourId="habits" TourSteps="tourSteps" />
    }

    @if (!_showSecondColumn)
    {
        <HabitsStatisticsComponent PageStateChanged="_pageStateChanged" />
    }

</div>

@if (_showSecondColumn)
{
    <div class="col child-column px-0 px-md-1 py-1">
        @if (_showHabitComponent)
        {
            <HabitComponent Habit="HabitService.SelectedHabit" HabitChanged="OnHabitChanged" CloseSelected="CloseSelected" />
        }
        else
        {
            <HabitsStatisticsComponent PageStateChanged="_pageStateChanged" />
        }
    </div>
}

@code {
    TourStep[] tourSteps;

    public Habits()
    {
        tourSteps = new TourStep[]
        {
            new() { Text = "Habit's priority." },
            new() { Text = "Habit's title." },
            new() { Text = "The time elapsed since the habit was last completed and the habit's selected interval ratio. The interval ratio can be set in Search, Filter, Sort." },
            new() { Text = "Mark the habit as done.", Show = () => !ClientState.Settings.ShowSmallCalendar },
            new() { Text = "Habit's items.", Show = () => ClientState.Settings.ShowItemList },
            new() { Text = "Click on a day on the small calendar to mark the habit as done.", Show = () => ClientState.Settings.ShowSmallCalendar },
            new() { Text = "Set the habit's priority.", Show = () => _showHabitComponent },
            new() { Text = "Change the habit's title.", Show = () => _showHabitComponent },
            new() { Text = "Mark the habit as done.", Show = () => _showHabitComponent && !ClientState.Settings.ShowSmallCalendar },
            new() { Text = "Delete the habit.", Show = () => _showHabitComponent },
            new() { Text = "Close the habit.", Show = () => _showHabitComponent },
            new() { Text = "Habit's items.", Show = () => _showHabitComponent },
            new() { Text = "Click on a day on the large calendar to mark the habit as done.", Show = () => _showHabitComponent && ClientState.Settings.ShowLargeCalendar },
            new() { Text = "Set the habit's desired repeat interval.", Show = () => _showHabitComponent },
            new() { Text = "Set the habit's desired duration.", Show = () => _showHabitComponent },
            new() { Text = "Start the timer to start timing the habit's duration. Stopping the timer completes the habit.", Show = () => _showHabitComponent },
            new() { Text = "Time spent on the habit.", Show = () => _showHabitComponent },
            new() { Text = "The time elapsed since the habit was last completed.", Show = () => _showHabitComponent },
            new() { Text = "Habit's desired repeat interval.", Show = () => _showHabitComponent },
            new() { Text = "Habit's average repeat interval.", Show = () => _showHabitComponent },
            new() { Text = "The ratio of habit's average repeat interval to the habit's desired repeat interval.", Show = () => _showHabitComponent },
            new() { Text = "How many times was the habit completed and when was the habit last completed.", Show = () => _showHabitCompletedTimes },
            new() { Text = "Set the habit's category.", Show = () => _showHabitComponent },
            new() { Text = "Set the habit's color.", Show = () => _showHabitComponent && ClientState.Settings.ShowColor },
            new() { Text = "The date when the habit was created and the date when the habit was last updated.", Show = () => _showHabitComponent && ClientState.Settings.ShowCreatedUpdated },
        };
    }

    private async Task StartTour(string tourId)
    {
        await GTourService.StartTour(tourId);
    }

    [Parameter]
    public long? Id { get; set; }

    [Parameter]
    public bool IsEmbedded { get; set; }

    [Parameter]
    public bool IsCollapsedChanged { get; set; }

    [Parameter]
    public EventCallback OnIsCollapsedChanged { get; set; }

    [CascadingParameter(Name = "StateChanged")]
    public bool StateChanged { get; set; }

    [CascadingParameter(Name = "WindowDimensions")]
    public Dimensions? WindowDimensions { get; set; }

    [CascadingParameter(Name = "DynamicComponentType")]
    public Type? DynamicComponentType { get; set; }

    string? _dynamicComponentTypeName;

    bool _showSecondColumn => !IsEmbedded && WindowDimensions?.Width >= 1280;

    bool _displayBasedOnWidth => !IsEmbedded && columnWidth >= 400;

    bool _showHabitComponent => Id is not null && HabitService.SelectedHabit is not null && HabitService.NewHabit is null;

    bool _showHabitCompletedTimes => Id is not null && HabitService.SelectedHabit is not null && HabitService.NewHabit is null && HabitService.SelectedHabit.TimesDone is not null && HabitService.SelectedHabit.LastTimeDoneAt is not null;

    InputTextImmediate? inputElement;

    bool shouldFocus;
    bool _shouldFocusEdit;
    bool _prevShowHabitComponent;
    long _lastSelectedId;
    bool _pageStateChanged;

    protected override async Task OnInitializedAsync()
    {
        await HabitService.Initialize();
    }

    protected override async Task OnParametersSetAsync()
    {
        await HabitService.SetSelectedHabit(Id);
    }

    ElementReference columnRef;
    int columnWidth;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        bool dynamicComponentVisibilityChanged = (_dynamicComponentTypeName is null && DynamicComponentType is not null) || (_dynamicComponentTypeName is not null && DynamicComponentType is null);

        _dynamicComponentTypeName = DynamicComponentType?.Name;

        if (firstRender || dynamicComponentVisibilityChanged)
        {
            // use JsInterop to get the dimensions of the main div in this razor component
            Dimensions columnDimensions = await JsInterop.GetElementDimensions(columnRef);

            // columnWidth is needed for the CalendarComponent
            columnWidth = columnDimensions.Width;

            // TODO:: try to make it work without this
            // or at least move it up the hierarchy, before Habits render for the first time
            // or don't render habits if columnWidth == 0
            StateHasChanged();
            // TODO:: make it work without JsInterop and use @media for each day
            // even better: get <body> dimensions once at startup, calculate everything else from that
            // first render can be empty in MainLayout, with everything else rendering only if body dimensions are set
        }

        if (shouldFocus && inputElement?.Element is not null)
        {
            shouldFocus = false;
            await inputElement.Element.Value.FocusAsync();
        }

        bool editOpened = !_prevShowHabitComponent && _showHabitComponent;
        bool editClosed = _prevShowHabitComponent && !_showHabitComponent;
        _prevShowHabitComponent = _showHabitComponent;

        if (_shouldFocusEdit && editOpened)
        {
            _shouldFocusEdit = false;
            await JsInterop.FocusFirstIn("#habit-component");
        }
        else if (editClosed && _lastSelectedId != 0)
        {
            await JsInterop.FocusElementById($"habit-item-{_lastSelectedId}");
        }
    }

    void AddNew()
    {
        HabitService.NewHabit = new() { Color = "bg-info-subtle" };
        shouldFocus = true;
    }

    async Task OpenSelected(long id)
    {
        _lastSelectedId = id;
        _shouldFocusEdit = true;
        if (IsEmbedded)
        {
            Id = id;
            await HabitService.SetSelectedHabit(Id);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("skipNextScrollTo");

            NavigationManager.NavigateTo($"/habits/{id}");
        }
    }

    async Task CloseSelected()
    {
        _pageStateChanged = !_pageStateChanged;

        if (IsEmbedded)
        {
            Id = null;
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("skipNextScrollTo");

            NavigationManager.NavigateTo("/habits");
        }
    }

    void OnHabitChanged()
    {
        _pageStateChanged = !_pageStateChanged;
        StateHasChanged();
    }

    async Task OnAddHabit()
    {
        await HabitService.AddHabit();
        _pageStateChanged = !_pageStateChanged;
    }

    async Task OnToggleCollapsed(CategoryModel? category)
    {
        if (category is not null)
        {
            await CategoryService.ToggleCollapsed(category);
            await OnIsCollapsedChanged.InvokeAsync();
        }
    }

    async Task OnToggleCompletionRule(CategoryModel? category)
    {
        if (category is not null)
            await CategoryService.ToggleCompletionRule(category);
    }

    string GetCompletionColor(CompletionRule rule, int doneThisWeek, int total)
    {
        if (rule == CompletionRule.All)
        {
            if (doneThisWeek == total) return "success";
            if (doneThisWeek > 0) return "warning";
            return "danger";
        }
        return doneThisWeek > 0 ? "success" : "danger";
    }

    async Task OnMarkAsDone(HabitModel habit)
    {
        await HabitService.MarkAsDone(habit);
        _pageStateChanged = !_pageStateChanged;
    }

    IEnumerable<(CategoryModel? Category, IEnumerable<HabitModel> Habits)> GetHabitGroups()
    {
        if (!ClientState.Settings.ShowGroupedByCategory || CategoryService.Categories is null)
        {
            yield return (null, HabitService.GetHabits());
            yield break;
        }

        QueryParameters queryParameters = SearchFilterService.GetQueryParameters(ClientState.Settings);

        foreach (CategoryModel category in CategoryService.Categories)
        {
            if (ClientState.Settings.CategoryFilterDisplay == FilterDisplay.CheckBoxes || ClientState.Settings.CategoryFilterDisplay == FilterDisplay.RadioButtons)
            {
                if (ClientState.Settings.HiddenCategoryIds.Contains(category.Id))
                    continue;
            }
            else if (ClientState.Settings.CategoryFilterDisplay == FilterDisplay.SelectOptions)
            {
                if (ClientState.Settings.SelectedCategoryId is not null && ClientState.Settings.SelectedCategoryId != category.Id)
                    continue;
            }

            List<HabitModel> habits = category.Habits.FilterHabits(queryParameters).ToList();
            if (habits.Count > 0)
                yield return (category, habits);
        }

        List<HabitModel> uncategorized = ClientState.Habits!.Values.Where(x => x.CategoryId == 0).FilterHabits(queryParameters).ToList();
        if (uncategorized.Count > 0)
            yield return (null, uncategorized);
    }

    string ToHighestValueString(TimeSpan span)
    {
        return span.Days > 0 ? span.Days + " d"
                             : span.Hours > 0 ? span.Hours + " h"
                                              : span.Minutes + " m";
    }
}
