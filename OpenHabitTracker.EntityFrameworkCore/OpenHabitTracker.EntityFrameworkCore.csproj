<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0;net10.0-windows</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.10" />
    <!-- CVE-2025-6965: EF Core Sqlite still pins the vulnerable 2.1.11 native SQLite.
         PrivateAssets=all is load-bearing - without it the desktop lib flows into the android
         build, its linux .so gets packaged into the APK over the real android lib (XA4301),
         and SqliteConnection crashes at startup. The pin therefore covers only this project's
         own graph; every host csproj carries its own shipping pin.
         Remove all of them when Microsoft.EntityFrameworkCore.Sqlite references 2.1.12+ itself. -->
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" Version="2.1.12" PrivateAssets="all" />

  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OpenHabitTracker\OpenHabitTracker.csproj" />
  </ItemGroup>

</Project>
